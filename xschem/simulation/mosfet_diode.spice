.param temp=27
.control
save all
save @n.xm4.nsg13_lv_nmos[ids]
save @n.xm2.nsg13_lv_nmos[ids]
tran 5n 500n
plot v(Vgs) v(Vds)
plot @n.xm4.nsg13_lv_nmos[ids] @n.xm2.nsg13_lv_nmos[ids]
.endc


 .lib cornerMOSlv.lib mos_tt

