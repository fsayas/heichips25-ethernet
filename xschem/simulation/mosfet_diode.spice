**.subckt mosfet_diode
XM4 Vgs Vgs GND GND sg13_lv_nmos w=10u l=4u ng=1 m=1
Vdd Vds GND 1.5
XM1 Vds Vds Vgs Vgs sg13_lv_nmos w=10u l=10u ng=1 m=1
XM2 net1 Vgs GND GND sg13_lv_nmos w=50u l=1u ng=5 m=1
R1 Vds net1 100 m=1
