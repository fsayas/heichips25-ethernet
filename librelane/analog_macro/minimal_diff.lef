VERSION 5.7 ;
  NOWIREEXTENSIONATPIN ON ;
  DIVIDERCHAR "/" ;
  BUSBITCHARS "[]" ;
MACRO minimal_diff
  CLASS BLOCK ;
  FOREIGN minimal_diff ;
  ORIGIN 45.850 17.000 ;
  SIZE 100.000 BY 28.000 ;
  PIN ethernet_dn
    DIRECTION INOUT ;
    USE SIGNAL ;
    ANTENNAGATEAREA 0.039000 ;
    PORT
      LAYER GatPoly ;
        RECT 2.750 -2.370 3.250 -2.000 ;
        RECT 1.895 -2.500 2.075 -2.370 ;
        RECT 2.225 -2.500 4.075 -2.370 ;
        RECT 4.225 -2.500 4.405 -2.370 ;
      LAYER Metal1 ;
        RECT 2.750 -2.370 3.250 -1.620 ;
    END
  END ethernet_dn
  PIN ethernet_dp
    DIRECTION INOUT ;
    USE SIGNAL ;
    ANTENNAGATEAREA 0.039000 ;
    PORT
      LAYER GatPoly ;
        RECT 1.895 -0.500 2.075 -0.370 ;
        RECT 2.225 -0.500 4.075 -0.370 ;
        RECT 4.225 -0.500 4.405 -0.370 ;
        RECT 2.750 -0.870 3.250 -0.500 ;
      LAYER Metal1 ;
        RECT 2.750 -1.250 3.250 -0.500 ;
    END
  END ethernet_dp
  PIN in_p
    DIRECTION INPUT ;
    USE SIGNAL ;
    ANTENNADIFFAREA 0.201000 ;
    PORT
      LAYER Metal1 ;
        RECT 2.020 -0.230 4.280 -0.070 ;
    END
  END in_p
  PIN in_n
    DIRECTION INPUT ;
    USE SIGNAL ;
    ANTENNADIFFAREA 0.201000 ;
    PORT
      LAYER Metal1 ;
        RECT 2.020 -2.645 2.280 -2.640 ;
        RECT 4.020 -2.645 4.280 -2.640 ;
        RECT 2.020 -2.805 4.280 -2.645 ;
    END
  END in_n
  PIN VPWR
    DIRECTION INOUT ;
    USE POWER ;
    PORT
      LAYER Metal1 ;
        RECT 4.020 -1.305 4.280 -0.640 ;
        RECT 3.950 -1.585 5.725 -1.305 ;
        RECT 4.020 -2.230 4.280 -1.585 ;
      LAYER Metal2 ;
        RECT 5.235 -1.675 6.795 -1.205 ;
      LAYER Metal3 ;
        RECT 6.200 -1.790 8.285 -1.130 ;
      LAYER Metal4 ;
        RECT 7.630 -1.970 8.575 1.980 ;
      LAYER Metal5 ;
        RECT -45.850 1.000 54.150 11.000 ;
    END
  END VPWR
  PIN VGND
    DIRECTION INOUT ;
    USE GROUND ;
    PORT
      LAYER Metal1 ;
        RECT 2.020 -1.055 2.280 -0.640 ;
        RECT 0.105 -1.715 2.280 -1.055 ;
        RECT 2.020 -2.230 2.280 -1.715 ;
      LAYER Metal2 ;
        RECT -1.785 -1.905 0.885 -0.840 ;
      LAYER Metal3 ;
        RECT -3.980 -2.085 -0.690 -0.630 ;
      LAYER Metal4 ;
        RECT -4.385 -8.050 -2.580 -0.420 ;
      LAYER Metal5 ;
        RECT -45.850 -17.000 54.150 -7.000 ;
    END
  END VGND
END minimal_diff
END LIBRARY

